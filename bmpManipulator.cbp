<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="bmpManipulator" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/bmpManipulator" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Option parameters="--escala-de-grises --espejar-horizontal --espejar-vertical --aumentar-contraste=10 --reducir-contraste=20 .\img\unlam.bmp --tonalidad-azul=50 --tonalidad-verde=5 --tonalidad-roja=15 --achicar=10 --rotar-derecha --rotar-izquierda --concatenar-horizontal --concatenar-vertical --comodin --recortar=30 prueba.bmp --negativo --negativo" />
				<Compiler>
					<Add option="-g" />
				</Compiler>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/bmpManipulator" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
		</Compiler>
		<Unit filename="bmp_io.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="bmp_io.h" />
		<Unit filename="filtros.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="filtros.h" />
		<Unit filename="interfaz.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="interfaz.h" />
		<Unit filename="main.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="tipos.h" />
		<Extensions>
			<lib_finder disable_auto="1" />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
